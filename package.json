{
  "name": "@getcommunity/client-styleguides",
  "description": "A collection of reusable styles for GetCommunity client projects.",
  "version": "0.0.33",
  "author": "@GetCommunity <ryan@getcommunity.com> (https://github.com/GetCommunity)",
  "contributors": [
    "Joey Grable <joey@getcommunity.com> (https://joeygrable.com)"
  ],
  "dependencies": {
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@getcommunity/config-prettier": "^0.0.16",
    "@getcommunity/config-typescript": "^0.0.18",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "solid-js": "^1.9.12",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [],
  "license": "ISC",
  "main": "./dist/getcommunity.cjs",
  "module": "./dist/getcommunity.js",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": "getcommunity/client-styleguides.git",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo node_modules dist",
    "dev:preview": "vite serve dev",
    "dev:watch": "tsdown --watch",
    "format": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,md,mdx}\"",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit --jsx preserve ./src/**/*"
  },
  "sideEffects": false,
  "source": "./src/index.ts",
  "type": "module",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts",
        "./dist/index.d.ts"
      ]
    }
  }
}
